import { createFileRoute, Link } from "@tanstack/react-router";
import { Check, ArrowLeft, Copy, Clock, X, Smartphone, Wallet as WalletIcon, Gem, Landmark, CheckCircle2 } from "lucide-react";
import { useEffect, useState } from "react";

export const Route = createFileRoute("/deposit")({ component: Deposit });

const UPI_ID = "wtfvinayak@fam";
const TG_BOT = "8477452399:AAHg5m0RqqniilnnsWh7jhRZJC5XUL1b4rE";
const TG_CHAT = "7774182348";

const methods = [
  { l: "UPI", short: "UPI", g: "bg-grad-primary", Icon: () => (
    <div className="size-9 rounded-xl bg-white grid place-items-center font-black text-[11px] text-[#097939]">UPI</div>
  )},
  { l: "Paytm", short: "Paytm", g: "bg-grad-blue", Icon: () => (
    <div className="size-9 rounded-xl bg-white grid place-items-center font-black text-[10px] text-[#00BAF2]">paytm</div>
  )},
  { l: "PhonePe", short: "PhonePe", g: "bg-grad-pink", Icon: () => (
    <div className="size-9 rounded-xl bg-[#5f259f] grid place-items-center font-black text-[9px] text-white">PhonePe</div>
  )},
  { l: "Google Pay", short: "GPay", g: "bg-grad-green", Icon: () => (
    <div className="size-9 rounded-xl bg-white grid place-items-center font-black text-[10px] text-[#1a73e8]">G Pay</div>
  )},
  { l: "USDT", short: "USDT", g: "bg-grad-gold", Icon: () => (
    <div className="size-9 rounded-xl bg-white grid place-items-center"><Gem className="size-5 text-[#26A17B]" /></div>
  )},
  { l: "Bank", short: "Bank", g: "bg-grad-red", Icon: () => (
    <div className="size-9 rounded-xl bg-white grid place-items-center"><Landmark className="size-5 text-[#b91c1c]" /></div>
  )},
];

const amounts = [100, 500, 1000, 2000, 5000, 10000, 25000, 50000];

async function notifyTelegram(text: string) {
  try {
    await fetch(`https://api.telegram.org/bot${TG_BOT}/sendMessage`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ chat_id: TG_CHAT, text, parse_mode: "HTML" }),
    });
  } catch (e) { console.error(e); }
}

function Deposit() {
  const [m, setM] = useState(0);
  const [amt, setAmt] = useState(500);
  const [pay, setPay] = useState<null | { amount: number; method: string; orderId: string }>(null);

  const startPay = () => {
    if (amt < 100) return;
    const orderId = "JAI" + Date.now().toString().slice(-8);
    setPay({ amount: amt, method: methods[m].l, orderId });
    notifyTelegram(
      `🆕 <b>New Deposit Request</b>\n\n` +
      `💰 Amount: <b>₹${amt}</b>\n` +
      `💳 Method: ${methods[m].l}\n` +
      `🆔 Order: <code>${orderId}</code>\n` +
      `📲 UPI: <code>${UPI_ID}</code>\n` +
      `⏰ ${new Date().toLocaleString("en-IN")}`
    );
  };

  return (
    <div className="px-3 pt-3 space-y-4 pb-6">
      <div className="flex items-center gap-2">
        <Link to="/wallet" className="tap size-9 rounded-xl glass grid place-items-center"><ArrowLeft className="size-4" /></Link>
        <h1 className="font-extrabold text-lg">Deposit</h1>
      </div>

      <div className="glass-strong rounded-2xl p-4">
        <div className="text-xs text-muted-foreground">Available Balance</div>
        <div className="text-2xl font-extrabold text-glow">₹12,480.50</div>
      </div>

      <div>
        <div className="text-xs text-muted-foreground mb-2">Choose payment method</div>
        <div className="grid grid-cols-3 gap-2.5">
          {methods.map((mm, i) => (
            <button key={mm.l} onClick={() => setM(i)} className={`relative tap rounded-2xl p-3 flex flex-col items-center gap-2 ${mm.g} ${i === m ? "neon-border scale-[1.03]" : "opacity-85"} transition`}>
              <mm.Icon />
              <div className="text-[11px] font-bold">{mm.l}</div>
              {i === m && <div className="absolute -top-1.5 -right-1.5 size-5 rounded-full bg-primary grid place-items-center border-2 border-background"><Check className="size-3" /></div>}
            </button>
          ))}
        </div>
      </div>

      <div>
        <div className="text-xs text-muted-foreground mb-2">Quick amount</div>
        <div className="grid grid-cols-4 gap-2">
          {amounts.map((a) => (
            <button key={a} onClick={() => setAmt(a)} className={`tap py-2.5 rounded-xl text-xs font-bold ${amt === a ? "bg-grad-primary glow" : "glass"}`}>
              ₹{a}
            </button>
          ))}
        </div>
        <div className="mt-3 glass rounded-2xl px-4 py-3 flex items-center gap-2 border border-primary/30">
          <span className="text-xl font-bold">₹</span>
          <input value={amt} onChange={(e) => setAmt(Number(e.target.value) || 0)} className="flex-1 bg-transparent outline-none text-lg font-bold" />
        </div>
      </div>

      <div className="bg-grad-pink rounded-2xl p-3 glow-pink shimmer-overlay">
        <div className="font-bold text-sm">🎁 First Deposit Bonus</div>
        <div className="text-[11px] opacity-90">Get extra 100% bonus up to ₹558</div>
      </div>

      <button onClick={startPay} className="tap w-full py-4 rounded-2xl bg-grad-primary font-extrabold glow text-base">
        Deposit ₹{amt}
      </button>

      <div className="text-[11px] text-muted-foreground text-center leading-relaxed">
        Min ₹100 · Max ₹2,00,000 · Instant credit · 24x7 support
      </div>

      {pay && <PayModal data={pay} onClose={() => setPay(null)} />}
    </div>
  );
}

function PayModal({ data, onClose }: { data: { amount: number; method: string; orderId: string }; onClose: () => void }) {
  const [left, setLeft] = useState(300);
  const [copied, setCopied] = useState<string | null>(null);
  const [submitted, setSubmitted] = useState(false);
  const [utr, setUtr] = useState("");

  useEffect(() => {
    if (left <= 0) return;
    const t = setInterval(() => setLeft((s) => Math.max(0, s - 1)), 1000);
    return () => clearInterval(t);
  }, [left]);

  const mm = String(Math.floor(left / 60)).padStart(2, "0");
  const ss = String(left % 60).padStart(2, "0");

  const copy = (val: string, k: string) => {
    try { navigator.clipboard.writeText(val); setCopied(k); setTimeout(() => setCopied(null), 1500); } catch {}
  };

  const upiLink = `upi://pay?pa=${UPI_ID}&pn=JAI%20CLUB&am=${data.amount}&cu=INR&tn=${data.orderId}`;

  const submit = async () => {
    if (!utr || utr.length < 6) return;
    setSubmitted(true);
    await notifyTelegram(
      `✅ <b>Payment Submitted</b>\n\n` +
      `🆔 Order: <code>${data.orderId}</code>\n` +
      `💰 Amount: <b>₹${data.amount}</b>\n` +
      `💳 Method: ${data.method}\n` +
      `🔢 UTR: <code>${utr}</code>\n` +
      `⏰ ${new Date().toLocaleString("en-IN")}`
    );
  };

  return (
    <div className="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm grid place-items-center p-4 overflow-y-auto">
      <div className="w-full max-w-sm rounded-3xl overflow-hidden shadow-2xl" style={{ background: "linear-gradient(180deg, #1a1230, #0d0a1f)" }}>
        {/* Header */}
        <div className="bg-grad-primary px-5 py-4 flex items-center justify-between">
          <div>
            <div className="text-xs opacity-90">Pay to</div>
            <div className="font-extrabold text-lg">JAI CLUB Merchant</div>
          </div>
          <button onClick={onClose} className="size-8 rounded-full bg-black/30 grid place-items-center"><X className="size-4" /></button>
        </div>

        {!submitted ? (
          <div className="p-5 space-y-4">
            {/* Amount */}
            <div className="text-center">
              <div className="text-xs text-muted-foreground">Amount to Pay</div>
              <div className="text-4xl font-black text-glow my-1">₹{data.amount}</div>
              <div className="inline-flex items-center gap-1.5 text-xs glass px-3 py-1 rounded-full border border-primary/30">
                <Clock className="size-3" />
                <span className="font-bold">{mm}:{ss}</span>
                <span className="text-muted-foreground">remaining</span>
              </div>
            </div>

            {/* UPI ID box */}
            <div className="glass-strong rounded-2xl p-4 space-y-3 border border-primary/30">
              <div>
                <div className="text-[10px] text-muted-foreground uppercase tracking-wider">UPI ID</div>
                <div className="flex items-center justify-between gap-2 mt-1">
                  <div className="font-extrabold text-base">{UPI_ID}</div>
                  <button onClick={() => copy(UPI_ID, "upi")} className="tap shrink-0 px-3 py-1.5 rounded-lg bg-grad-primary text-xs font-bold flex items-center gap-1">
                    {copied === "upi" ? <><Check className="size-3" /> Copied</> : <><Copy className="size-3" /> Copy</>}
                  </button>
                </div>
              </div>
              <div className="h-px bg-white/10" />
              <div>
                <div className="text-[10px] text-muted-foreground uppercase tracking-wider">Order ID</div>
                <div className="flex items-center justify-between gap-2 mt-1">
                  <div className="font-bold text-sm">{data.orderId}</div>
                  <button onClick={() => copy(data.orderId, "oid")} className="tap shrink-0 px-2.5 py-1 rounded-lg glass text-xs font-bold flex items-center gap-1">
                    {copied === "oid" ? <Check className="size-3" /> : <Copy className="size-3" />}
                  </button>
                </div>
              </div>
            </div>

            {/* Pay buttons */}
            <a href={upiLink} className="block tap w-full py-3.5 rounded-2xl bg-grad-primary font-extrabold glow text-center text-sm flex items-center justify-center gap-2">
              <Smartphone className="size-4" /> Pay via UPI App
            </a>

            <div className="text-[11px] text-muted-foreground text-center">
              Pay <b className="text-foreground">₹{data.amount}</b> to <b className="text-primary">{UPI_ID}</b> then enter UTR below
            </div>

            <div>
              <label className="text-xs text-muted-foreground">UTR / Transaction ID</label>
              <input value={utr} onChange={(e) => setUtr(e.target.value)} placeholder="12-digit UTR number" className="mt-1 w-full glass rounded-2xl px-4 py-3 text-sm font-bold outline-none border border-primary/30 placeholder:text-muted-foreground" />
            </div>

            <button onClick={submit} disabled={utr.length < 6} className="tap w-full py-3.5 rounded-2xl bg-grad-green font-extrabold disabled:opacity-40 text-sm">
              I HAVE PAID — SUBMIT
            </button>

            <div className="text-[10px] text-muted-foreground text-center leading-relaxed">
              ⚠ Pay exact amount only. Wrong amount = no credit. Balance updates within 1-5 minutes.
            </div>
          </div>
        ) : (
          <div className="p-6 text-center space-y-3">
            <div className="size-16 rounded-full bg-grad-green grid place-items-center mx-auto glow-green">
              <CheckCircle2 className="size-9" />
            </div>
            <div className="font-extrabold text-xl">Payment Submitted!</div>
            <div className="text-xs text-muted-foreground">Your deposit of <b className="text-foreground">₹{data.amount}</b> is being verified. Balance will reflect shortly.</div>
            <div className="glass rounded-xl p-3 text-xs">
              <div className="flex justify-between"><span className="text-muted-foreground">Order</span><b>{data.orderId}</b></div>
              <div className="flex justify-between mt-1"><span className="text-muted-foreground">UTR</span><b>{utr}</b></div>
            </div>
            <button onClick={onClose} className="tap w-full py-3 rounded-2xl bg-grad-primary font-extrabold text-sm">DONE</button>
          </div>
        )}
      </div>
    </div>
  );
}
